rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Email check runs FIRST (cheap, no doc access) so admin works
      // even if the users/{uid} doc doesn't exist yet. The role-based
      // path is a secondary fallback and is guarded by exists() to
      // prevent a missing doc from erroring the whole rule.
      return isAuthenticated() && (
        (request.auth.token.email == "seo574486@gmail.com" &&
         request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin')
      );
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isFamilyMember(familyId) {
      let userData = getUserData();
      return isAuthenticated() && (
        (userData != null && userData.familyId == familyId) ||
        (exists(/databases/$(database)/documents/families/$(familyId)) &&
         request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.members)
      );
    }

    function isParentOfFamily(familyId) {
      let userData = getUserData();
      return isAuthenticated() && userData != null && userData.familyId == familyId && userData.role == 'parent';
    }

    function isOwnerOfFamily(familyId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/families/$(familyId)) &&
        get(/databases/$(database)/documents/families/$(familyId)).data.ownerUid == request.auth.uid;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.role in ['parent', 'child', 'admin'] &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.size() > 0;
    }

    // An update is "role-preserving" if it does NOT change the role field.
    // Used to prevent privilege escalation via self-update.
    function rolePreserving() {
      return !('role' in request.resource.data.diff(resource.data).affectedKeys()) ||
             request.resource.data.role == resource.data.role;
    }

    // Allow a role change ONLY when it matches the role recorded for this
    // user in their (newly-joined) family doc. The join flow writes the
    // family.members entry FIRST, then updates users.role — so by the time
    // this rule fires, family.members[uid] already reflects the truth.
    // This lets a user who joined via the child code legitimately demote
    // themselves to 'child', while still blocking arbitrary self-promotion
    // from 'child' to 'parent'.
    function roleMatchesFamilyRecord() {
      let newRole = request.resource.data.role;
      let newFamilyId = request.resource.data.familyId;
      return newFamilyId is string &&
        exists(/databases/$(database)/documents/families/$(newFamilyId)) &&
        get(/databases/$(database)/documents/families/$(newFamilyId)).data.members[request.auth.uid] == newRole;
    }

    // ===============================================================
    // Users
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      // Self-updates allowed. Role changes are blocked unless the new role
      // matches what the user's family doc already records for them — that
      // is the only legitimate way for a user to change roles (joining a
      // family via the child invite code).
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) &&
                        (rolePreserving() || roleMatchesFamilyRecord())) || isAdmin();
      allow delete: if isAdmin();
    }

    // ===============================================================
    // Families
    // ===============================================================

    match /families/{familyId} {
      // Family doc is readable by any authenticated user so the "join by
      // invite code" flow (which reads families/{inviteCode}) still works.
      // Sensitive material (parent password hash) must NOT live on this doc —
      // it belongs under /private/config below.
      allow read: if isAuthenticated();
      // On create, the caller must be the declared owner. ownerUid is the
      // master-of-the-family marker and is immutable from this point on.
      allow create: if isAuthenticated() &&
                    request.resource.data.ownerUid == request.auth.uid;

      // Updates: three legitimate paths.
      //  (a) Owner — full control, but ownerUid stays frozen.
      //  (b) Parent (non-owner) — may edit family fields BUT may not touch
      //      `members` / `memberNames` / `ownerUid` (only owner removes
      //      members; only the join flow appends them).
      //  (c) Any authed user — join flow: append ONLY their own slot to
      //      `members` and `memberNames`. Cannot remove or modify other
      //      members. Cannot change ownerUid.
      // NOTE: `.get('field', default)` is used instead of direct field
      // access so that legacy docs missing the field don't error out the
      // whole rule (`undefined.diff(...)` throws and blocks the write).
      allow update: if isAdmin() ||
        // Write-once ownerUid migration: legacy families created before
        // the dual-code RBAC refactor have no ownerUid. A parent member
        // of such a family may claim ownership exactly once. Subsequent
        // edits go through the normal owner-path branch below.
        (isAuthenticated() &&
          !('ownerUid' in resource.data.keys()) &&
          request.resource.data.get('ownerUid', '') == request.auth.uid &&
          request.auth.uid in resource.data.get('members', {}) &&
          resource.data.get('members', {})[request.auth.uid] == 'parent') ||
        (isOwnerOfFamily(familyId) &&
          request.resource.data.ownerUid == resource.data.ownerUid) ||
        (isParentOfFamily(familyId) &&
          request.resource.data.get('ownerUid', '') == resource.data.get('ownerUid', '') &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['members', 'memberNames'])) ||
        (isAuthenticated() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'memberNames']) &&
          request.resource.data.get('ownerUid', '') == resource.data.get('ownerUid', '') &&
          request.resource.data.get('members', {}).diff(resource.data.get('members', {})).affectedKeys().hasOnly([request.auth.uid]) &&
          request.auth.uid in request.resource.data.get('members', {}) &&
          request.resource.data.get('memberNames', {}).diff(resource.data.get('memberNames', {})).affectedKeys().hasOnly([request.auth.uid]) &&
          // Self-join / self-edit never grants parent role. Existing
          // members must go through the owner/parent path above to be
          // promoted, and first-time joiners start as 'child'. This
          // plugs the "set members[uid]='parent' → reload → useAuth
          // self-heal promotes users.role" escalation path.
          request.resource.data.get('members', {})[request.auth.uid] == 'child');
      allow delete: if isAdmin();

      // -----------------------------------------------------------
      // Private config (parent password hash, secrets) — parents only
      // -----------------------------------------------------------
      match /private/{docId} {
        allow read, write: if isParentOfFamily(familyId) || isAdmin();
      }

      // -----------------------------------------------------------
      // Shared catalogs — rewards, categories
      // Members can read; only parents can write.
      // -----------------------------------------------------------
      match /rewards/{rewardId} {
        allow read: if isFamilyMember(familyId) || isAdmin();
        allow write: if isParentOfFamily(familyId) || isAdmin();
      }

      match /categories/{categoryId} {
        allow read: if isFamilyMember(familyId) || isAdmin();
        allow write: if isParentOfFamily(familyId) || isAdmin();
      }

      // -----------------------------------------------------------
      // Family Feed (mini SNS) — family members only
      // -----------------------------------------------------------
      match /feed/{postId} {
        allow read: if isFamilyMember(familyId) || isAdmin();
        // Create: any family member, and authorUid must match the caller.
        allow create: if isFamilyMember(familyId) &&
                      request.resource.data.authorUid == request.auth.uid;
        // Update: author may update freely; other members may only change
        // the `reactions` map (to toggle their OWN reaction — the diff
        // of the reactions map must touch only their uid slot) or the
        // denormalized `commentCount` / `lastCommentAt` fields (touched
        // when they add a comment). This blocks cross-user reaction
        // tampering — previously a bug allowed any family member to
        // overwrite the entire reactions map.
        allow update: if isFamilyMember(familyId) && (
          resource.data.authorUid == request.auth.uid ||
          (request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['reactions', 'commentCount', 'lastCommentAt']) &&
           request.resource.data.get('reactions', {})
             .diff(resource.data.get('reactions', {}))
             .affectedKeys()
             .hasOnly([request.auth.uid]))
        );
        allow delete: if isFamilyMember(familyId) &&
                      resource.data.authorUid == request.auth.uid;

        match /comments/{commentId} {
          allow read: if isFamilyMember(familyId) || isAdmin();
          allow create: if isFamilyMember(familyId) &&
                        request.resource.data.authorUid == request.auth.uid;
          allow update, delete: if isFamilyMember(familyId) &&
                        resource.data.authorUid == request.auth.uid;
        }
      }

      // -----------------------------------------------------------
      // Children
      // -----------------------------------------------------------
      // Parent creates/deletes. Non-parent family members (children)
      // may update a small whitelist of fields that reflect legitimate
      // in-game actions (points, inventory, achievements, etc.). The
      // whitelist blocks injection of unknown fields (e.g. a rogue
      // `role` field or direct writes to `name`) from the mobile SDK.
      // It does NOT bound the *values* of those fields — defense in
      // depth against tampering would require Cloud Functions.
      match /children/{childId} {
        allow read: if isFamilyMember(familyId) || isAdmin();
        allow create, delete: if isParentOfFamily(familyId) || isAdmin();
        allow update: if isParentOfFamily(familyId) || isAdmin() ||
          (isFamilyMember(familyId) &&
           request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly([
               'totalPoints',
               'lifetimeEarned',
               'totalCompleted',
               'streak',
               'longestStreak',
               'lastCompletedDate',
               'achievements',
               'inventory',
               'level',
               'avatar',     // emoji avatar — set by child via picker
               'avatarUrl',  // photo avatar — set by upload flow
             ]));

        // Quests: parents manage; non-parent family members (children) may
        // only toggle `completed` / `completedAt` and the group-bonus
        // bookkeeping flag. Past-date guard is enforced client-side
        // (Firestore rules can't reliably compute "today" in user-local tz).
        match /quests/{questId} {
          allow read: if isFamilyMember(familyId) || isAdmin();
          allow create, delete: if isParentOfFamily(familyId) || isAdmin();
          allow update: if isParentOfFamily(familyId) || isAdmin() ||
            (isFamilyMember(familyId) &&
             request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['completed', 'completedAt', 'groupBonusClaimed']));
        }

        // Quest groups — bundles of quests that award a bonus when all
        // members complete on the same day.
        match /questGroups/{groupId} {
          allow read: if isFamilyMember(familyId) || isAdmin();
          allow write: if isParentOfFamily(familyId) || isAdmin();
        }

        // History: create is open to family members (quest toggles and
        // backdated completions write from child UI), but mutation and
        // deletion are parent/admin only so audit trail can't be
        // rewritten. Required fields are validated on create to block
        // malformed rows. Point values are NOT bounded by rules —
        // that requires a Cloud Function.
        match /history/{historyId} {
          allow read: if isFamilyMember(familyId) || isAdmin();
          allow create: if isFamilyMember(familyId) &&
            request.resource.data.keys().hasAll(['timestamp']) &&
            request.resource.data.get('type', 'quest') in ['quest', 'reward', 'penalty', 'group-bonus'];
          // Quest-uncheck flow needs to delete the matching history row,
          // so deletes are allowed for family members. Updates are not
          // used anywhere and stay parent/admin-only.
          allow delete: if isFamilyMember(familyId) || isAdmin();
          allow update: if isParentOfFamily(familyId) || isAdmin();
        }

        // Achievements — parents / admin only. The live badge list is
        // also denormalized onto the child doc's `achievements` array
        // (covered by the field whitelist above); this subcollection
        // is for structured per-badge documents and should not be
        // self-writable by children.
        match /achievements/{achievementId} {
          allow read: if isFamilyMember(familyId) || isAdmin();
          allow write: if isParentOfFamily(familyId) || isAdmin();
        }
      }
    }

    // ===============================================================
    // Admin — Announcements (all authed read, admin write)
    // ===============================================================
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ===============================================================
    // Admin — Audit logs (admin only, append-only)
    // ===============================================================
    match /adminAuditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // ===============================================================
    // Admin — Collection-group reads for moderation & stats
    // Required because collection-group queries are evaluated against
    // rules declared with `/{path=**}/...` patterns, not nested paths.
    // ===============================================================
    match /{path=**}/feed/{postId} {
      allow read: if isAdmin();
    }
    match /{path=**}/quests/{questId} {
      allow read: if isAdmin();
    }

    // ===============================================================
    // Default deny
    // ===============================================================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "seo574486@gmail.com" && request.auth.token.email_verified == true));
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isFamilyMember(familyId) {
      let userData = getUserData();
      return isAuthenticated() && (
        (userData != null && userData.familyId == familyId) ||
        (exists(/databases/$(database)/documents/families/$(familyId)) &&
         request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.members)
      );
    }

    function isParentOfFamily(familyId) {
      let userData = getUserData();
      return isAuthenticated() && userData != null && userData.familyId == familyId && userData.role == 'parent';
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.role in ['parent', 'child'] &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.size() > 0;
    }

    // An update is "role-preserving" if it does NOT change the role field.
    // Used to prevent privilege escalation via self-update.
    function rolePreserving() {
      return !('role' in request.resource.data.diff(resource.data).affectedKeys()) ||
             request.resource.data.role == resource.data.role;
    }

    // ===============================================================
    // Users
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      // Self-updates allowed but role field is frozen (admins can still override).
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && rolePreserving()) || isAdmin();
      allow delete: if isAdmin();
    }

    // ===============================================================
    // Families
    // ===============================================================

    match /families/{familyId} {
      // Family doc is readable by any authenticated user so the "join by
      // invite code" flow (which reads families/{inviteCode}) still works.
      // Sensitive material (parent password hash) must NOT live on this doc —
      // it belongs under /private/config below.
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // Parents can update their family doc; any authed user can append
      // themselves to `members` (used by join flow).
      allow update: if isParentOfFamily(familyId) || isAdmin() ||
                    (isAuthenticated() &&
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']));
      allow delete: if isAdmin();

      // -----------------------------------------------------------
      // Private config (parent password hash, secrets) — parents only
      // -----------------------------------------------------------
      match /private/{docId} {
        allow read, write: if isParentOfFamily(familyId) || isAdmin();
      }

      // -----------------------------------------------------------
      // Shared catalogs — rewards, categories
      // Members can read; only parents can write.
      // -----------------------------------------------------------
      match /rewards/{rewardId} {
        allow read: if isFamilyMember(familyId) || isAdmin();
        allow write: if isParentOfFamily(familyId) || isAdmin();
      }

      match /categories/{categoryId} {
        allow read: if isFamilyMember(familyId) || isAdmin();
        allow write: if isParentOfFamily(familyId) || isAdmin();
      }

      // -----------------------------------------------------------
      // Family Feed (mini SNS) — family members only
      // -----------------------------------------------------------
      match /feed/{postId} {
        allow read: if isFamilyMember(familyId) || isAdmin();
        // Create: any family member, and authorUid must match the caller.
        allow create: if isFamilyMember(familyId) &&
                      request.resource.data.authorUid == request.auth.uid;
        // Update: author may update freely; other members may only change
        // the `reactions` map (to toggle their own reaction) or the
        // denormalized `commentCount` / `lastCommentAt` fields (touched
        // when they add a comment).
        allow update: if isFamilyMember(familyId) && (
          resource.data.authorUid == request.auth.uid ||
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['reactions', 'commentCount', 'lastCommentAt'])
        );
        allow delete: if isFamilyMember(familyId) &&
                      resource.data.authorUid == request.auth.uid;

        match /comments/{commentId} {
          allow read: if isFamilyMember(familyId) || isAdmin();
          allow create: if isFamilyMember(familyId) &&
                        request.resource.data.authorUid == request.auth.uid;
          allow update, delete: if isFamilyMember(familyId) &&
                        resource.data.authorUid == request.auth.uid;
        }
      }

      // -----------------------------------------------------------
      // Children
      // -----------------------------------------------------------
      match /children/{childId} {
        allow read: if isFamilyMember(familyId) || isAdmin();
        allow write: if isFamilyMember(familyId) || isAdmin();

        // Quests: parents manage; non-parent family members (children) may
        // only toggle `completed` / `completedAt` and the group-bonus
        // bookkeeping flag. Past-date guard is enforced client-side
        // (Firestore rules can't reliably compute "today" in user-local tz).
        match /quests/{questId} {
          allow read: if isFamilyMember(familyId) || isAdmin();
          allow create, delete: if isParentOfFamily(familyId) || isAdmin();
          allow update: if isParentOfFamily(familyId) || isAdmin() ||
            (isFamilyMember(familyId) &&
             request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['completed', 'completedAt', 'groupBonusClaimed']));
        }

        // Quest groups — bundles of quests that award a bonus when all
        // members complete on the same day.
        match /questGroups/{groupId} {
          allow read: if isFamilyMember(familyId) || isAdmin();
          allow write: if isParentOfFamily(familyId) || isAdmin();
        }

        // History is written on quest toggle / reward purchase — any family
        // member can read/write their own child's history.
        match /history/{historyId} {
          allow read, write: if isFamilyMember(familyId) || isAdmin();
        }

        // Achievements unlocked per child — family members can read; writes
        // happen via the app after unlock events.
        match /achievements/{achievementId} {
          allow read: if isFamilyMember(familyId) || isAdmin();
          allow write: if isFamilyMember(familyId) || isAdmin();
        }
      }
    }

    // ===============================================================
    // Default deny
    // ===============================================================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

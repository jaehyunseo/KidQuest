  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3030 --host=localhost",
    "dev:emulator": "cross-env VITE_USE_EMULATOR=1 vite --port=3030 --host=localhost",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test:unit": "node scripts/unit-tests.mjs",
    "test:smoke": "node scripts/smoke-extended.mjs",
    "test:rules": "node scripts/test-rules.mjs",
    "test:storage": "node scripts/test-storage-rules.mjs",
    "test:scenario": "node scripts/scenario-eval.mjs",
    "cap:sync": "npm run build && cap sync android",
    "cap:open": "cap open android",
    "cap:run": "npm run build && cap sync android && cap run android",
    "cap:build": "npm run build && cap sync android && cd android && gradlew bundleRelease",
    "deploy": "npm run build && firebase deploy --only hosting,firestore:ai-studio-2ec230ec-f2ca-4672-be64-eebc32cf5343:rules,storage --project prod",
    "deploy:hosting": "npm run build && firebase deploy --only hosting --project prod",
    "deploy:rules": "firebase deploy --only firestore:ai-studio-2ec230ec-f2ca-4672-be64-eebc32cf5343:rules,storage --project prod"
  },

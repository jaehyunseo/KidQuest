{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:emulator": "cross-env VITE_USE_EMULATOR=1 vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test:unit": "node scripts/unit-tests.mjs",
    "test:smoke": "node scripts/smoke-extended.mjs",
    "test:rules": "node scripts/test-rules.mjs",
    "test:rules:ci": "node scripts/with-java.mjs firebase emulators:exec --only firestore \"node scripts/test-rules.mjs\"",
    "test:storage": "node scripts/test-storage-rules.mjs",
    "test:storage:ci": "node scripts/with-java.mjs firebase emulators:exec --only storage \"node scripts/test-storage-rules.mjs\"",
    "test:rules:all": "node scripts/with-java.mjs firebase emulators:exec \"node scripts/run-all-rules-tests.mjs\"",
    "emulators": "node scripts/with-java.mjs firebase emulators:start --only auth,firestore,storage"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/canvas-confetti": "^1.9.0",
    "@vitejs/plugin-react": "^5.0.4",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.12.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.59.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "firebase-tools": "^15.14.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}

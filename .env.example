# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ADSENSE_SLOT_PARENT: AdSense ad unit slot ID for the parent
# dashboard banner. Leave unset to disable parent-dashboard ads (useful
# during AdSense review or for local dev). The AdSense client ID
# (pub-9886893201801989) is hardcoded in index.html and AdBanner.tsx
# since it's a public value required for site verification.
# Create the slot in AdSense → Ads → Ad units → Display ads.
ADSENSE_SLOT_PARENT=""
